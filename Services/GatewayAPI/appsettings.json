{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://0.0.0.0:8000",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:8000"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "subscription-route": {
        "ClusterId": "subscription-cluster",
        "Match": {
          "Path": "/api/subscription/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "questions-route": {
        "ClusterId": "questions-cluster",
        "Match": {
          "Path": "/api/questions/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "tests-route": {
        "ClusterId": "tests-cluster",
        "Match": {
          "Path": "/api/tests/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "exams-route": {
        "ClusterId": "exams-cluster",
        "Match": {
          "Path": "/api/exams/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "admin-route": {
        "ClusterId": "admin-cluster",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "master-route": {
        "ClusterId": "master-cluster",
        "Match": {
          "Path": "/api/master/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "quiz-route": {
        "ClusterId": "quiz-cluster",
        "Match": {
          "Path": "/api/quiz/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "qualification-route": {
        "ClusterId": "qualification-cluster",
        "Match": {
          "Path": "/api/qualification/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      },
      "webhooks-route": {
        "ClusterId": "subscription-cluster",
        "Match": {
          "Path": "/api/webhooks/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "subscription-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:56925"
          }
        }
      },
      "questions-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:56916"
          }
        }
      },
      "tests-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:56917"
          }
        }
      },
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "exams-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000"
          }
        }
      },
      "admin-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:56923"
          }
        }
      },
      "master-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5009"
          }
        }
      },
      "quiz-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:56918"
          }
        }
      },
      "qualification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5011"
          }
        }
      }
    }
  },
  "Swagger": {
    "Title": "RankUp API Gateway",
    "Description": "Gateway for RankUp Ed-Tech Platform",
    "Version": "v1"
  }
}
