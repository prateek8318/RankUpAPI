# RankUpAPI Environment Configuration
# Copy this file to .env and update values for your environment

# Database Configuration
MSSQL_SA_PASSWORD=RankUp@SecurePass1
MSSQL_PORT=1433

# Gateway Port (External Access)
GATEWAY_PORT=5087

