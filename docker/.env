# RankUpAPI Docker environment
# Copy to .env and adjust. Do not commit .env with real secrets.

# SQL Server (used when running full stack in Docker)
MSSQL_SA_PASSWORD=RankUp@SecurePass1
MSSQL_PORT=14333

# Gateway port on host (API entry point)
GATEWAY_PORT=5087

# Optional: use external SQL Server instead of container
# Set to "true" to skip starting sqlserver and use host/external DB
# USE_EXTERNAL_SQL=false
